# Application Configuration
APP_NAME=Ticket Backend
APP_VERSION=1.0.0
DEBUG=False
PORT=8000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
#
# Choose your database backend by setting DB_TYPE:
# - "sqlite"      : Development/Testing (default if no config provided)
# - "mysql"       : Production MySQL
# - "postgresql"  : Production PostgreSQL
#
# If DB_TYPE is not set, the system auto-detects:
#   PostgreSQL config (PG_*) > MySQL config (MYSQL_*) > SQLite (default)
#
# =============================================================================

# Database Type Selection (optional - auto-detects if not set)
DB_TYPE=sqlite
# DB_TYPE=mysql
# DB_TYPE=postgresql

# SQLite Configuration (Development/Testing)
# No external setup needed - file-based database
# Path can be relative or absolute
SQLITE_PATH=data/ticket_booking.db

# MySQL Configuration (Production)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ticket_db
MYSQL_USER=root
MYSQL_PASSWORD=your_password

# PostgreSQL Configuration (Alternative Production)
# Option 1: Full connection string (easiest for cloud like Render, Railway)
# PG_PATH=postgresql://ticket_user:password@host:5432/ticket_db
#
# Option 2: Individual components (better for local/Docker)
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=ticket_db
# PG_USER=postgres
# PG_PASSWORD=password

# =============================================================================
# JWT & SECURITY
# =============================================================================
JWT_SECRET_KEY=your-secret-key-change-in-production-very-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@example.com
EMAIL_FROM=noreply@ticketing.com

# CORS Origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=9437184
